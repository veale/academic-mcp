# ===========================================================================
# Academic MCP Server — Environment Configuration
# ===========================================================================
# Copy to .env and fill in the values you need.

# ---------------------------------------------------------------------------
# External APIs
# ---------------------------------------------------------------------------

# Required: Unpaywall needs a valid email (no key needed)
UNPAYWALL_EMAIL=your@email.com

# Optional: Semantic Scholar API key for higher rate limits
# Get one at https://www.semanticscholar.org/product/api#api-key
SEMANTIC_SCHOLAR_API_KEY=

# Optional: OpenAlex API key for premium rate limits
# Get one at https://openalex.org/pricing
# When set, Authorization: Bearer header is used instead of mailto polite pool
OPENALEX_API_KEY=

# ---------------------------------------------------------------------------
# OA aggregator and web search fallback
# ---------------------------------------------------------------------------

# CORE.ac.uk API key — free, 300M+ records, 40M+ full-text PDFs
# Register at https://core.ac.uk/services/api
# Rate: 5 single requests per 10 seconds (free tier)
CORE_API_KEY=

# Serper.dev — Google search results, 2,500 free queries (no credit card)
# Get one at https://serper.dev
SERPER_API_KEY=

# Brave Search API — own index, $5/mo free credits (~1K queries)
# Get one at https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=

# ---------------------------------------------------------------------------
# SSRN authenticated access
# ---------------------------------------------------------------------------

# Cookie string for authenticated SSRN access. Two formats supported:
#
# Option A — Cookie Quick Manager TSV export (easiest):
#   Install the "Cookie Quick Manager" Firefox extension, log into SSRN,
#   export all ssrn.com cookies as text, and paste below (one cookie per line,
#   tab-separated: domain TAB hostOnly TAB path TAB secure TAB expires TAB name TAB value).
#
# Option B — JSON array:
#   [{"name":"SSRN_TOKEN","value":"...","domain":".ssrn.com","path":"/"}]
#
# Key cookies to include: SSRN_TOKEN, AWSELB, and any __cf_bm / cf_clearance.
# Cookies expire after a few days to weeks — re-export when access stops working.
SSRN_COOKIES=

# ---------------------------------------------------------------------------
# Zotero auto-import
# ---------------------------------------------------------------------------

# When true, PDFs fetched from the web are automatically imported into your
# local Zotero library with full Crossref metadata (title, authors, journal,
# volume/issue/pages, abstract). Requires Zotero desktop to be running.
# The .article.json text cache is always kept; only the PDF moves to Zotero.
AUTO_IMPORT_TO_ZOTERO=false

# ---------------------------------------------------------------------------
# Ex Libris Primo (institutional library catalogue)
# ---------------------------------------------------------------------------

# Your institution's Primo hostname (e.g. library.example.ac.uk)
PRIMO_DOMAIN=

# View ID — institution-specific (e.g. 44UCL_INST:UCL_VU2)
# Find it in the vid= parameter of your library's Primo search URL
PRIMO_VID=

# Search tab — usually "Everything" or "default_tab"
PRIMO_TAB=Everything

# Search scope — usually "MyInst_and_CI" (local + central discovery index)
PRIMO_SEARCH_SCOPE=MyInst_and_CI

# ---------------------------------------------------------------------------
# Institutional proxy
# ---------------------------------------------------------------------------

# GOST or HTTP/SOCKS5 proxy for institutional access to paywalled content.
# Examples: socks5://localhost:1080  |  http://localhost:8080
# Forwarded to the remote Scrapling browser when SCRAPLING_MCP_URL is set.
GOST_PROXY_URL=

# ---------------------------------------------------------------------------
# Zotero — SQLite (preferred, fastest — no API needed)
# ---------------------------------------------------------------------------

# Path to Zotero's main database (read-only access)
ZOTERO_SQLITE_PATH=~/Zotero/zotero.sqlite

# Path to Zotero's attachment storage (for direct PDF reads + ft-cache)
ZOTERO_LOCAL_STORAGE=~/Zotero/storage

# If your WebDAV server stores zotero/<key>.zip on a local mount,
# point here to skip HTTP entirely (e.g. Nextcloud data dir)
ZOTERO_WEBDAV_LOCAL_PATH=

# ---------------------------------------------------------------------------
# Zotero — Local API (Zotero 7/8 desktop)
# ---------------------------------------------------------------------------

# Requires: Zotero > Settings > Advanced > "Allow other applications..."
ZOTERO_LOCAL_ENABLED=true
ZOTERO_LOCAL_HOST=localhost
ZOTERO_LOCAL_PORT=23119

# ---------------------------------------------------------------------------
# Zotero — Web API (api.zotero.org)
# ---------------------------------------------------------------------------

# Get your API key + user ID at https://www.zotero.org/settings/keys
ZOTERO_API_KEY=
ZOTERO_USER_ID=
ZOTERO_LIBRARY_TYPE=user
# For group libraries: set ZOTERO_LIBRARY_TYPE=group and fill in:
ZOTERO_GROUP_ID=

# ---------------------------------------------------------------------------
# Zotero — WebDAV (self-hosted or provider)
# ---------------------------------------------------------------------------

# URL should point to your zotero/ folder on the server
ZOTERO_WEBDAV_URL=
ZOTERO_WEBDAV_USER=
ZOTERO_WEBDAV_PASS=

# ---------------------------------------------------------------------------
# PDF fetching & caching
# ---------------------------------------------------------------------------

# Enable Scrapling stealth browser for anti-bot evasion
USE_STEALTH_BROWSER=true

# Remote Scrapling MCP server (optional — avoids running a local browser).
# Start the remote with: scrapling mcp --http --host 0.0.0.0 --port 8000
# When set, the local server connects as an MCP client over SSE and calls
# the remote scraping tool. The GOST_PROXY_URL (if set) is forwarded in
# the tool arguments so the remote browser routes through your institution.
# When empty, Scrapling runs locally with a local Chromium instance.
SCRAPLING_MCP_URL=

# Directory to cache downloaded PDFs
PDF_CACHE_DIR=~/.cache/academic-mcp/pdfs

# Max cache size in bytes before LRU eviction (default: 2 GB)
PDF_CACHE_MAX_BYTES=2147483648

# Max text length returned to the LLM (characters)
MAX_CONTEXT_LENGTH=100000

# ---------------------------------------------------------------------------
# PDF extraction backend
# ---------------------------------------------------------------------------

# Use pymupdf4llm for Markdown extraction (tables, multi-column, bold/italic).
# Falls back to the legacy pipeline on failure.
USE_PYMUPDF4LLM=true
