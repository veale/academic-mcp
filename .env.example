# ===========================================================================
# Academic MCP Server — Environment Configuration
# ===========================================================================
# Copy to .env and fill in the values you need.

# ---------------------------------------------------------------------------
# External APIs
# ---------------------------------------------------------------------------

# Required: Unpaywall needs a valid email (no key needed)
UNPAYWALL_EMAIL=your@email.com

# Optional: Semantic Scholar API key for higher rate limits
# Get one at https://www.semanticscholar.org/product/api#api-key
SEMANTIC_SCHOLAR_API_KEY=

# Optional: GOST proxy for institutional access
# Examples: socks5://localhost:1080  |  http://localhost:8080
GOST_PROXY_URL=

# ---------------------------------------------------------------------------
# Zotero — SQLite (preferred, fastest — no API needed)
# ---------------------------------------------------------------------------

# Path to Zotero's main database (read-only access)
ZOTERO_SQLITE_PATH=~/Zotero/zotero.sqlite

# Path to Zotero's attachment storage (for direct PDF reads + ft-cache)
ZOTERO_LOCAL_STORAGE=~/Zotero/storage

# If your WebDAV server stores zotero/<key>.zip on a local mount,
# point here to skip HTTP entirely (e.g. Nextcloud data dir)
ZOTERO_WEBDAV_LOCAL_PATH=

# ---------------------------------------------------------------------------
# Zotero — Local API (Zotero 7/8 desktop)
# ---------------------------------------------------------------------------

# Requires: Zotero > Settings > Advanced > "Allow other applications..."
ZOTERO_LOCAL_ENABLED=true
ZOTERO_LOCAL_HOST=localhost
ZOTERO_LOCAL_PORT=23119

# ---------------------------------------------------------------------------
# Zotero — Web API (api.zotero.org)
# ---------------------------------------------------------------------------

# Get your API key + user ID at https://www.zotero.org/settings/keys
ZOTERO_API_KEY=
ZOTERO_USER_ID=
ZOTERO_LIBRARY_TYPE=user
# For group libraries: set ZOTERO_LIBRARY_TYPE=group and fill in:
ZOTERO_GROUP_ID=

# ---------------------------------------------------------------------------
# Zotero — WebDAV (self-hosted or provider)
# ---------------------------------------------------------------------------

# URL should point to your zotero/ folder on the server
ZOTERO_WEBDAV_URL=
ZOTERO_WEBDAV_USER=
ZOTERO_WEBDAV_PASS=

# ---------------------------------------------------------------------------
# PDF fetching & caching
# ---------------------------------------------------------------------------

# Enable Scrapling stealth browser for anti-bot evasion
USE_STEALTH_BROWSER=true

# Remote Scrapling MCP server (optional — avoids running a local browser).
# Start the remote with: scrapling mcp --http --host 0.0.0.0 --port 8000
# When set, the local server connects as an MCP client over SSE and calls
# the remote scraping tool.  The GOST_PROXY_URL (if set) is forwarded in
# the tool arguments so the remote browser routes through your institution.
# When empty, Scrapling runs locally with a local Chromium instance.
SCRAPLING_MCP_URL=

# Directory to cache downloaded PDFs
PDF_CACHE_DIR=~/.cache/academic-mcp/pdfs

# Max cache size in bytes before LRU eviction (default: 2 GB)
PDF_CACHE_MAX_BYTES=2147483648

# Max text length returned to the LLM (characters)
MAX_CONTEXT_LENGTH=100000
